# 复制为 grafana.env 后填写（勿命名为 .env，否则 Compose 会把 URL 里的 $__all 当成变量）
# cp grafana.env.example grafana.env

# 必填
GRAFANA_TOKEN=
# Dashboard 完整 URL；含 $__all 等 $ 变量时请用单引号（双引号会被 godotenv 误展开）
GRAFANA_URL='https://grafana.example.com/d/your-dashboard/uid?orgId=1&from=now-24h&to=now&var-datasource=$__all'

# 服务端渲染（RENDER_FULL_PAGE=true 时 height=-1 截取整页 Dashboard）
RENDER_FULL_PAGE=true
RENDER_WIDTH=1920
RENDER_TIMEOUT=180
RENDER_KIOSK=true

# 本地截图保留天数（超过则自动删除，默认 30 天）
SCREENSHOT_RETENTION_DAYS=30

# 定时：每天下午 17:00:00（Asia/Shanghai）
TZ=Asia/Shanghai
SCHEDULE_HOUR=17
SCHEDULE_MINUTE=0
SCHEDULE_SECOND=0
RUN_ON_START=false

# HTTP 触发（容器默认 server 模式，GET /trigger）
LISTEN_ADDR=:8111
# TRIGGER_SECRET=          # 可选，设置后请求需 ?token=该值
# ENABLE_SCHEDULER=false    # true 时同时跑每日定时任务

# Lark 群推送（必填；默认 API 为 https://open.larksuite.com）
# LARK_MSG_TITLE=最近24小时视频监控图表
LARK_APP_ID=
LARK_APP_SECRET=
LARK_CHAT_ID=
# LARK_API_BASE=https://open.larksuite.com
# LARK_HTTP_TIMEOUT=120
